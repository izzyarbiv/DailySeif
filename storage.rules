rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // PDFs — authenticated users can read, write
    match /pdfs/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 20 * 1024 * 1024  // 20 MB max
        && request.resource.contentType.matches('application/pdf');
    }

    // Thumbnails — authenticated users can read, admins can write
    match /thumbnails/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024   // 5 MB max
        && request.resource.contentType.matches('image/.*');
    }

    // Avatars — users can read/write their own avatar
    match /avatars/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 2 * 1024 * 1024   // 2 MB max
        && request.resource.contentType.matches('image/.*');
    }
  }
}
