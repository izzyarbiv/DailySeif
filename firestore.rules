rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Lessons — published lessons are public (landing page shows them
    // to signed-out visitors); signed-in users can also read drafts.
    // Only admins can write.
    match /lessons/{lessonId} {
      allow read: if request.auth != null || resource.data.isPublished == true;
      allow create, update, delete: if request.auth != null &&
        (request.auth.token.email in ['izzy.arbiv@gmail.com', 'dailyseif613@gmail.com'] ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    // Users — only the owner can read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Progress — users can only read/write their own progress
    match /progress/{docId} {
      allow read: if request.auth != null &&
        resource != null && resource.data.userId == request.auth.uid;
      allow write: if request.auth != null &&
        (resource == null || resource.data.userId == request.auth.uid) &&
        request.resource.data.userId == request.auth.uid;
    }

    // Notes — users can only access their own notes
    match /notes/{noteId} {
      allow read, write: if request.auth != null &&
        (resource == null || resource.data.userId == request.auth.uid);
    }
  }
}
