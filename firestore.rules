rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Lessons — anyone authenticated can read published lessons
    // Only admins can write
    match /lessons/{lessonId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null &&
        (request.auth.token.email == 'izzy.arbiv@gmail.com' ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    // Users — only the owner can read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Progress — users can only read/write their own progress
    match /progress/{docId} {
      allow read: if request.auth != null &&
        resource != null && resource.data.userId == request.auth.uid;
      allow write: if request.auth != null &&
        (resource == null || resource.data.userId == request.auth.uid) &&
        request.resource.data.userId == request.auth.uid;
    }

    // Notes — users can only access their own notes
    match /notes/{noteId} {
      allow read, write: if request.auth != null &&
        (resource == null || resource.data.userId == request.auth.uid);
    }
  }
}
